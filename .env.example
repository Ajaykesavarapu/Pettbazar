# ============================================================
# PettBazar — Production Environment Variables
# ============================================================
# Copy this file to .env and fill in the values before deploying.
# NEVER commit the .env file to version control.
# ============================================================

# Server
NODE_ENV=production
PORT=8080

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/pettbazar

# CORS — allowed origin for API requests (your domain)
CORS_ORIGIN=https://pettbazar.in

# EmailJS (these are public keys, safe for client-side)
VITE_EMAILJS_PUBLIC_KEY=ISKx4EaoX_BjJFyYB
VITE_EMAILJS_SERVICE_ID=service_63o4w4s

# Logging
LOG_LEVEL=info
